// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  username       String   @unique
  hashedPassword String
  role           String   @default("staff")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Patient {
  id                  String     @id @default(cuid())
  cardNumber          String     @unique
  name                String
  birthDate           String?
  sex                 String?
  policyNo            String?
  assessmentFileLink  String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  claims              Claim[]
}

model Claim {
  id                    String     @id @default(cuid())
  patientId             String
  patient               Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  // Patient Information
  date                  String?
  provider              String?
  
  // Information Section
  serviceDate           String?
  symptoms              String?
  preExistingCondition  Boolean @default(false)
  chronicMedications    Boolean @default(false)
  familyHistory         Boolean @default(false)
  additionalNotes       String?
  
  // Objective/Assessment Section
  clinicalFindings      String?
  cause                 String? // Accident, Dental, Maternity, Physical Illness, Preventive, Psychiatry, Work Related
  otherCause            String?
  assessmentAcute       Boolean @default(false)
  assessmentChronic     Boolean @default(false)
  assessmentConfirmed   Boolean @default(false)
  assessmentSuspected   Boolean @default(false)
  comments              String?
  
  // Medical Plan Section
  consultation          Boolean @default(false)
  physiotherapy         Boolean @default(false)
  laboratory            Boolean @default(false)
  radiology             Boolean @default(false)
  pharmacy              Boolean @default(false)
  otherMedical          String?
  preAuthorizationRequired Boolean @default(false)
  preAuthorizationDetails String?
  proposedTreatment     String?
  estimatedCost         String?
  
  // In-Patient Section
  lengthOfStay          String?
  inPatientProvider     String?
  inPatientCost         String?
  
  // Physician Info
  treatingPhysicianName String?
  telFax                String?
  signature             String? // Patient/Guardian signature (base64)
  physicianSignature    String? // Physician signature and stamp (base64)
  includeStamp          Boolean @default(false) // Render the practice stamp in the print view
  stampType             String? // Selected practice stamp: "chrisone" | "medone"
  
  // Almadallah Use Only
  approvedTariff        Boolean @default(false)
  approvalCode          String?
  
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
}
